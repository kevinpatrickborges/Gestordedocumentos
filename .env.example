########################################
# Aplicação
########################################
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

########################################
# Banco de Dados (Aplicação)
########################################
# Em produção, defina variáveis via ambiente/secret manager
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sgc_itep
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me
DATABASE_SSL=false

########################################
# Banco de Dados (Docker Compose - Postgres)
########################################
# Usado por docker-compose para o serviço postgres
POSTGRES_PASSWORD=change_me

########################################
# Autenticação
########################################
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=50m
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=replace_with_session_secret
SESSION_MAX_AGE=86400000

########################################
# URLs
########################################
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

